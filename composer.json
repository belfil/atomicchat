{
  "name": "belfil/atomic-chat",
  "description": "Atomic-fast, scalable messaging SDK for Laravel",
  "keywords": [
    "belfil",
    "atomic-chat",
    "laravel",
    "messaging",
    "chat"
  ],
  "homepage": "https://github.com/belfil/atomic-chat",
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Philip Belousov",
      "email": "belousovfilip@gmail.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/database": "^10.0|^11.0",
    "illuminate/support": "^10.0|^11.0"
  },
  "require-dev": {
    "larastan/larastan": "^2.9.12|^3.0",
    "phpstan/phpstan": "^1.12.17",
    "laravel/pint": "^1.27",
    "orchestra/testbench": "^8.22|^9.0",
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "Belfil\\AtomicChat\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Belfil\\AtomicChat\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
    "analyze:php": "vendor/bin/phpstan analyze",
    "lint:php": "vendor/bin/pint",
    "lint:md": "npx -y markdownlint-cli2 '**/*.md' '!node_modules' '!vendor'",
    "lint:yaml": "npx -y prettier --check \"**/*.{yml,yaml}\" --ignore-path .gitignore",
    "lint:yaml-fix": "npx -y prettier --write \"**/*.{yml,yaml}\"",
    "check": [
      "@lint:php",
      "@lint:md",
      "@analyze:php",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Belfil\\AtomicChat\\AtomicChatServiceProvider"
      ],
      "aliases": {
        "AtomicChat": "Belfil\\AtomicChat\\Facades\\AtomicChat"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
